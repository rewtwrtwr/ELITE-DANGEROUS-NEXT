# =============================================================================
# ELITE-DANGEROUS-NEXT — Git Ignore File
# =============================================================================
# This file ensures that only source code and essential configuration files
# are tracked in version control. All build artifacts, temporary files,
# personal data, and working notes are excluded.
# =============================================================================

# =============================================================================
# DEPENDENCIES
# =============================================================================
# Node.js packages are installed via npm and should never be committed.
# The package.json file defines all dependencies.
node_modules/
package-lock.json

# =============================================================================
# BUILD ARTIFACTS
# =============================================================================
# Compiled TypeScript output (dist/) and bundled frontend assets.
# These are generated by 'npm run build' and can be rebuilt from source.
dist/
public/assets/

# =============================================================================
# DATABASE FILES
# =============================================================================
# SQLite database contains personal game data and is specific to each user.
# Each developer/player has their own journal data.
# WAL (Write-Ahead Logging) files are temporary and auto-generated.
data/*.db
data/*.db-wal
data/*.db-shm
data/test-*.db

# =============================================================================
# LOG FILES
# =============================================================================
# Application logs contain runtime information and should not be committed.
# Log files are rotated automatically and can grow large.
logs/
*.log

# =============================================================================
# TEST OUTPUTS
# =============================================================================
# Temporary test output files and coverage reports.
# Coverage reports are generated during test runs.
test-*.txt
coverage/
coverage-output.txt

# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
# Environment files may contain sensitive data (API keys, secrets).
# Each developer should create their own .env file from .env.example.
.env
.env.local
.env.*.local

# =============================================================================
# LOCAL SCRIPTS & CONFIG
# =============================================================================
# Personal startup scripts and local configuration files.
start.bat
*.user

# =============================================================================
# SYSTEM FILES
# =============================================================================
# OS-specific metadata files that should not be committed.
.DS_Store              # macOS
Thumbs.db              # Windows

# =============================================================================
# TEMPORARY FILES
# =============================================================================
# Temporary files created during development or by editors.
*.tmp
*.tmp/
*.swp                # Vim swap files
*.swo
*~                   # Editor backup files

# =============================================================================
# ARCHIVE FILES
# =============================================================================
# Build archives are generated for releases and should not be committed.
*.zip
*.tar.gz
*.rar

# =============================================================================
# VISUAL STUDIO FILES
# =============================================================================
# IDE-specific user settings and build artifacts.
*.vs/
*.suo
*.user

# =============================================================================
# JUNK FILES
# =============================================================================
# Accidental files that should not be committed.
nul
