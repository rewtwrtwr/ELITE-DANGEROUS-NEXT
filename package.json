{
  "name": "elite-dangerous-next",
  "version": "1.0.0-beta",
  "type": "module",
  "description": "Мониторинг и обработка журнальных файлов Elite Dangerous в реальном времени",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build:client && tsx watch src/index.ts",
    "build": "npm run clean && npx tsc && npm run build:client",
    "build:client": "vite build",
    "clean": "node -e \"const fs=require('fs');if(fs.existsSync('dist'))fs.rmSync('dist',{recursive:true});\"",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.mjs",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.mjs --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.mjs --coverage",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.mjs --ci --coverage --maxWorkers=2",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "prepublishOnly": "node scripts/validate-clean-build.mjs",
    "validate:clean": "node scripts/validate-clean-build.mjs",
    "validate:fix": "node scripts/validate-clean-build.mjs --fix",
    "validate:dry-run": "node scripts/validate-clean-build.mjs --fix --dry-run",
    "validate:json": "node scripts/validate-clean-build.mjs --json"
  },
  "keywords": [
    "elite-dangerous",
    "assistant",
    "gaming",
    "websocket",
    "elite",
    "journal",
    "monitor"
  ],
  "author": "rewtwrtwr",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.18",
    "axios": "^1.13.5",
    "better-sqlite3": "^12.6.2",
    "cookie-parser": "^1.4.7",
    "cookie-session": "^2.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "8.3.1",
    "ini": "6.0.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.0",
    "preact": "^10.28.3",
    "ps-list": "9.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "winston": "^3.19.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tanstack/react-virtual": "^3.13.18",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.4",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "@vitejs/plugin-react": "^5.1.4",
    "0x": "^6.0.0",
    "autocannon": "^8.0.0",
    "clinic": "^13.0.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "8.57.0",
    "vite": "^7.3.1"
  }
}
